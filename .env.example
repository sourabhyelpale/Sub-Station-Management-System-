# Telegram bot settings
# TELEGRAM_CHAT_ID is a comma-separated list of maintainer chat IDs.
# Each new issue is assigned randomly to one of these maintainer IDs.
# TELEGRAM_CHAT_ID_SUPERVISOR is the supervisor who receives escalation messages
# if the issue is still open after TELEGRAM_DELAY_MINUTES.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id_1,your_telegram_chat_id_2
TELEGRAM_CHAT_ID_SUPERVISOR=your_telegram_chat_id_supervisor
TELEGRAM_DELAY_MINUTES=1
BACKEND_PORT=5000

# Frontend backend API base URL for development
REACT_APP_BACKEND_URL=http://localhost:5000
